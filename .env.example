APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Set true only for trusted Super Admin hosts — allows editing .env from Settings UI
ALLOW_ENV_EDITOR=false

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MOBILE_MONEY_PROVIDER=campay

# Campay
CAMPAY_ENABLED=true
CAMPAY_BASE_URL=https://www.campay.net/api
CAMPAY_DEMO_BASE_URL=https://demo.campay.net/api
CAMPAY_TOKEN=
CAMPAY_USERNAME=
CAMPAY_PASSWORD=
CAMPAY_APP_USERNAME=
CAMPAY_APP_PASSWORD=
CAMPAY_WEBHOOK_SECRET=
PAYMENT_SIMULATE=false

# Legacy Campay aliases (still supported)
MOMO_TOKEN=
MOMO_APP_USERNAME=
MOMO_APP_PASSWORD=
MOMO_APP_WEBHOOK=

# PawaPay
PAWAPAY_ENABLED=false
PAWAPAY_ENVIRONMENT=sandbox
PAWAPAY_SANDBOX_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_LIVE_BASE_URL=https://api.pawapay.io
PAWAPAY_API_TOKEN=
PAWAPAY_API_TOKEN_ID=
PAWAPAY_COUNTRY=CMR
PAWAPAY_CURRENCY=XAF
PAWAPAY_CHECKOUT_CALLBACK_URL="${APP_URL}/api/payments/pawapay/checkouts/callback"
PAWAPAY_DEPOSIT_CALLBACK_URL="${APP_URL}/api/payments/pawapay/deposits/callback"
PAWAPAY_PAYOUT_CALLBACK_URL="${APP_URL}/api/payments/pawapay/payouts/callback"
PAWAPAY_REFUND_CALLBACK_URL="${APP_URL}/api/payments/pawapay/refunds/callback"
# Legacy alias (optional) — defaults to deposit callback URL in config
PAWAPAY_CALLBACK_URL="${APP_URL}/api/payments/pawapay/deposits/callback"
PAWAPAY_VERIFY_CALLBACK_SIGNATURE=false
PAWAPAY_REQUEST_TIMEOUT=30
PAWAPAY_CONNECT_TIMEOUT=10

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_MINIMUM_AMOUNT=300

